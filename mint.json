{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Linksee Memory",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669",
    "anchors": {
      "from": "#10B981",
      "to": "#6366F1"
    }
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/michielinksee/linksee-memory"
    }
